{% extends 'base.html.twig' %}

{% block title %}Modifier la catégorie{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow" style="border: 2px solid #ff69b4; border-radius: 15px;">
                <div class="card-header text-white text-center" style="background-color: #ff69b4; border-radius: 13px 13px 0 0;">
                    <h4 class="mb-0"> Modifier la catégorie</h4>
                </div>
                <div class="card-body p-4">
                    {{ form_start(form) }}
                        <div class="mb-3">
                            <label class="form-label fw-bold">Nom de la catégorie</label>
                            {{ form_widget(form.name, {'attr': {'class': 'form-control', 'placeholder': 'Nom de la catégorie'}}) }}
                        </div>
                        <div class="d-flex gap-2">
                            <button class="btn w-100 text-white" style="background-color: #ff69b4; border: none;">
                                 Sauvegarder
                            </button>
                            <a href="{{ path('app_category_index') }}" class="btn btn-outline-secondary w-100">
                                Annuler
                            </a>
                        </div>
                    {{ form_end(form) }}
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}