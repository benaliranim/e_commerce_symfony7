{% extends 'base.html.twig' %}

{% block title %}Détail catégorie{% endblock %}

{% block body %}
<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow" style="border: 2px solid #ff69b4; border-radius: 15px;">
                <div class="card-header text-white text-center" style="background-color: #ff69b4; border-radius: 13px 13px 0 0;">
                    <h4 class="mb-0"> Détail de la catégorie</h4>
                </div>
                <div class="card-body p-4">
                    <table class="table table-borderless">
                        <tbody>
                            <tr>
                                <th>Id</th>
                                <td>{{ category.id }}</td>
                            </tr>
                            <tr>
                                <th>Nom</th>
                                <td>{{ category.name }}</td>
                            </tr>
                        </tbody>
                    </table>

                    <div class="d-flex gap-2 mt-3">
                        <a href="{{ path('app_category_edit', {'id': category.id}) }}" class="btn w-100 text-white" style="background-color: #ff69b4; border: none;">
                             Modifier
                        </a>
                        <a href="{{ path('app_category_index') }}" class="btn btn-outline-secondary w-100">
                            ← Retour
                        </a>
                    </div>

                    <div class="mt-3">
                        {{ include('category/_delete_form.html.twig') }}
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
{% endblock %}